+// 非上游: verb 圖示條中文 overlay。verb 名是烘進 VGA 影像(zone1 sprite 106-113)的英文,
+// hover verb 時 animate(2,1,IMG) 顯示。做法: 在 window2 疊層區填取樣底色蓋掉英文(合成 v1?v1:v0
+// → 非零疊層蓋過底圖), 再畫中文 verb 名。ha->id→中文對映見下(input.cpp 設 _chtVerbId)。
+void AGOSEngine::chtDrawVerbName() {
+	if (!_chtActive || _chtSubLang != 1 || !_chtHires || !_scaleBuf || getGameType() != GType_WW)
+		return;
+	const char *nm = nullptr;
+	switch (_chtVerbId) {
+	case 98:  nm = "\xac\x64\xac\xdd"; break;   // 查看
+	case 108: nm = "\xae\xb3\xa8\xfa"; break;   // 拿取
+	case 109: nm = "\xa5\xb4\xb6\x7d"; break;   // 打開
+	case 115: nm = "\xc3\xf6\xa4\x57"; break;   // 關上
+	case 116: nm = "\xa8\xcf\xa5\xce"; break;   // 使用
+	case 117: nm = "\xb5\xb9\xa4\xa9"; break;   // 給予
+	case 118: nm = "\xb2\xbe\xb0\xca"; break;   // 移動
+	case 119: nm = "\xa5\xe6\xbd\xcd"; break;   // 交談
+	default: return;
+	}
+	WindowBlock *w = _windowArray[2];
+	if (!w)
+		return;
+	int hx = w->x * 16, hy = w->y * 2, hw = w->width * 16, hh = w->height * 16;
+	if (hw <= 0 || hh <= 0)
+		return;
+	// 取樣底色(從 _backBuf window2 左上角)蓋英文; 避免 0(疊層透明哨兵)
+	byte bg = 0;
+	if (_backBuf) {
+		byte *bp = (byte *)_backBuf->getPixels();
+		int sx = w->x * 8, sy = w->y;
+		if (sx >= 0 && sx < _backBuf->w && sy >= 0 && sy < _backBuf->h)
+			bg = bp[sy * _backBuf->pitch + sx];
+	}
+	if (bg == 0)
+		bg = chtOutlineColor();
+	byte *hp = (byte *)_scaleBuf->getPixels();
+	uint pitch = _scaleBuf->pitch;
+	// 選 verb 時該框只有 verb 名 → 蓋滿整個 window2 疊層區(徹底蓋掉英文含 .ENTER 第二行)
+	for (int yy = 0; yy < hh; yy++) {
+		int py = hy + yy;
+		if (py < 0 || py >= _scaleBuf->h) continue;
+		int x0 = hx < 0 ? 0 : hx, x1 = hx + hw;
+		if (x1 > _scaleBuf->w) x1 = _scaleBuf->w;
+		for (int px = x0; px < x1; px++) hp[py * pitch + px] = bg;
+	}
+	int nchars = (int)strlen(nm) / 2;
+	int tw = nchars * _cht.fontW16;
+	int bx = hx + (hw - tw) / 2;
+	if (bx < hx) bx = hx;
+	int by = hy + (hh - _cht.fontH16) / 2;   // 垂直置中
+	if (by < hy) by = hy;
+	chtDrawMapLabel(bx, by, nm);
+}
