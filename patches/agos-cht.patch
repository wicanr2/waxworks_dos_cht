+// 非上游: 友善作弊 — 把玩家(item 1)背包裡帶計數(kOFNumber)的消耗品頂回滿。
+// Waxworks 的化學噴火槍(chemical sprayer)等武器用一次扣一次數,存在 objectFlagValue 的
+// kOFNumber 槽;無敵模式開啟時每幀補到 99,達成「次數無限不消耗」。只動玩家身上的物品,
+// 不碰場景/謎題計數,把副作用縮到最小。
+void AGOSEngine::chtRefillConsumables() {
+	Item *player = derefItem(1);
+	if (!player)
+		return;
+	Item *it = derefItem(player->child);
+	while (it) {
+		SubObject *so = (SubObject *)findChildOfType(it, kObjectType);
+		if (so && (so->objectFlags & kOFNumber)) {
+			uint offs = getOffsetOfChild2Param(so, kOFNumber);
+			if (so->objectFlagValue[offs] < 99)
+				so->objectFlagValue[offs] = 99;
+		}
+		it = derefItem(it->next);
+	}
+}
+
+// 非上游: 友善作弊 — 把當前房間裡所有「可拿取(kOFIcon)」物品直接送進玩家背包,回傳件數。
+// 讓卡關的現代玩家一鍵取得重要道具,不必逐一 search/take。
+int AGOSEngine::chtGiveRoomItems() {
+	Item *room = derefItem(_currentRoom);
+	Item *player = derefItem(1);
+	if (!room || !player)
+		return 0;
+	int n = 0;
+	Item *it = derefItem(room->child);
+	while (it) {
+		Item *nextIt = derefItem(it->next);   // setItemParent 會改 next,先存
+		SubObject *so = (SubObject *)findChildOfType(it, kObjectType);
+		if (so && (so->objectFlags & kOFIcon) && it != player) {
+			setItemParent(it, player);
+			n++;
+		}
+		it = nextIt;
+	}
+	return n;
+}
