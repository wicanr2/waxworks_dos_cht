+void AGOSEngine::chtDrawMapLabel(int x, int y, const char *big5) {
+	if (!_scaleBuf || !_cht.font16)
+		return;
+	const byte *s = (const byte *)big5;
+	int cx = x, fw = _cht.fontW16, fh = _cht.fontH16, bpr = _cht.fontBpr16;
+	byte tc = chtReadableColor(15);
+	byte *hp = (byte *)_scaleBuf->getPixels();
+	uint pitch = _scaleBuf->pitch;
+	while (*s) {
+		if (chtIsBig5Lead(*s) && s[1]) {
+			const byte *g = _cht.glyph16(s[0], s[1]);
+			s += 2;
+			if (g) {
+				for (int row = 0; row < fh; row++) {
+					int yy = y + row;
+					if (yy < 0 || yy >= _scaleBuf->h) continue;
+					const byte *gr = g + row * bpr;
+					byte *d = hp + yy * pitch + cx;
+					for (int col = 0; col < fw; col++) {
+						if (cx + col < 0 || cx + col >= _scaleBuf->w) break;
+						if (gr[col >> 3] & (0x80 >> (col & 7))) d[col] = tc;
+					}
+				}
+			}
+			cx += fw;
+		} else {
+			s++;
+		}
+	}
+}
+
+// 非上游: 友善作弊短暫提示 — 頂端中央畫一行中文, 先把該帶狀區清成透明(0), 避免連按疊字。
+// 位置固定在 x=300, 與 god 指示器(504)分開; god 指示器由 displayScreen 每幀重繪, 不受此清除影響。
+void AGOSEngine::chtStatusMessage(const char *big5) {
+	if (!_chtHires || !_scaleBuf)
+		return;
+	byte *hp = (byte *)_scaleBuf->getPixels();
+	uint pitch = _scaleBuf->pitch;
+	for (int yy = 2; yy < 22 && yy < _scaleBuf->h; yy++)
+		memset(hp + yy * pitch + 296, 0, 200);   // 清 x=296..496 帶狀區
+	chtDrawMapLabel(300, 4, big5);
+}
+
+// 非上游: WAXWORKS title logo 下方疊中文「蠟像館之謎」(24px)。畫在 640x400 疊層上,
+// 帶 1px 深色描邊 + 落影, 在火焰紅 logo/黑底上都清楚。每幀重繪(疊層會被抹除)。
+void AGOSEngine::chtDrawTitle() {
+	if (!_scaleBuf || !_cht.font)
+		return;
+	static const byte kTitle[] = { 0xc4,0xfa, 0xb9,0xb3, 0xc0,0x5d, 0xa4,0xa7, 0xc1,0xbc, 0 };  // 蠟像館之謎
+	int fw = _cht.fontW, fh = _cht.fontH, bpr = _cht.fontBpr;
+	int nchar = 5, gap = 6;
+	int totalW = nchar * fw + (nchar - 1) * gap;
+	int x0 = (_scaleBuf->w - totalW) / 2;    // 水平置中
+	int y0 = 250;                            // logo(疊層 y≈56..232)下方
+	byte fill = chtReadableColor(15), edge = chtOutlineColor();
+	byte *hp = (byte *)_scaleBuf->getPixels();
+	uint pitch = _scaleBuf->pitch;
+	const byte *s = kTitle;
+	int cx = x0;
+	while (*s) {
+		const byte *g = _cht.glyph(s[0], s[1]);
+		s += 2;
+		if (g) {
+			// 先描邊(8 向偏移填 edge), 再填字(fill) → 任意底色都可讀
+			for (int pass = 0; pass < 2; pass++) {
+				byte col = pass == 0 ? edge : fill;
+				for (int dy = -1; dy <= 1; dy++) for (int dx = -1; dx <= 1; dx++) {
+					if (pass == 0 && dx == 0 && dy == 0) continue;
+					if (pass == 1 && (dx != 0 || dy != 0)) continue;
+					for (int row = 0; row < fh; row++) {
+						int yy = y0 + row + (pass == 0 ? dy : 0);
+						if (yy < 0 || yy >= _scaleBuf->h) continue;
+						const byte *gr = g + row * bpr;
+						for (int c = 0; c < fw; c++) {
+							int xx = cx + c + (pass == 0 ? dx : 0);
+							if (xx < 0 || xx >= _scaleBuf->w) continue;
+							if (gr[c >> 3] & (0x80 >> (c & 7))) hp[yy * pitch + xx] = col;
+						}
+					}
+				}
+			}
+		}
+		cx += fw + gap;
+	}
+}
