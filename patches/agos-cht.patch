+// ===== 非上游: Waxworks 繁體中文繪字 (Big5 → hires _scaleBuf) =====
+// 亮度守門: 只救「暗到讀不到」的字色, 其餘保留原本 window 配色。
+// BT.601 luma (_currentPalette 0–255), Y < 90 視為太暗。
+#define CHT_LUMA(p, i) ((299 * (p)[(i) * 3] + 587 * (p)[(i) * 3 + 1] + 114 * (p)[(i) * 3 + 2]) / 1000)
+
+byte AGOSEngine::chtReadableColor(byte idx) {
+	const byte *p = _currentPalette;
+	if (idx != 0 && CHT_LUMA(p, idx) >= 90)
+		return idx;                      // 夠亮 → 原色不動
+	int best = -1, brightest = -1, brightestY = -1;
+	for (int i = 1; i < 256; i++) {      // 跳過 0(_scaleBuf 疊層透明哨兵)
+		int yv = CHT_LUMA(p, i);
+		if (yv > brightestY) { brightestY = yv; brightest = i; }
+		if (yv >= 90 && best < 0) best = i;
+	}
+	if (best > 0)
+		return (byte)best;
+	return (byte)(brightest > 0 ? brightest : 15);
+}
+
+// 描邊色: 調色盤中最暗的「非 0」索引 (0 是疊層透明哨兵, 不能拿來描邊)。
+byte AGOSEngine::chtOutlineColor() {
+	const byte *p = _currentPalette;
+	int best = 1, bestY = 1 << 30;
+	for (int i = 1; i < 256; i++) {
+		int yv = CHT_LUMA(p, i);
+		if (yv < bestY) { bestY = yv; best = i; }
+	}
+	return (byte)best;
+}
+
+// 把一個 Big5 字繪到 window 的 backend/hires surface。
+// hires: 用 16px 字模畫進 640x400 _scaleBuf 高解析疊層 (2x 座標, 16px=1 邏輯 8px 欄, 平鋪不重疊),
+//        帶 1px 描邊 → 壓在任意美術上都有輪廓。
+void AGOSEngine::chtDrawBig5OnSurface(WindowBlock *window, uint x, uint y, byte lead, byte trail) {
+	const byte *g = _cht.glyph16(lead, trail);
+	if (!g)
+		return;
+	const int fw = _cht.fontW16, fh = _cht.fontH16, bpr = _cht.fontBpr16;
+	byte tc = chtReadableColor((byte)(window->textColor ? window->textColor : 15));
+
+	if (_chtHires && _scaleBuf) {
+		byte ol = chtOutlineColor();
+		int bx = (int)x * 2, by = (int)y * 2;
+		byte *hp = (byte *)_scaleBuf->getPixels();
+		uint hpitch = _scaleBuf->pitch;
+		// pass 0: 描邊 (筆畫 8 鄰域塗最暗色); pass 1: 蓋本體字色
+		for (int pass = 0; pass < 2; pass++) {
+			for (int row = 0; row < fh; row++) {
+				const byte *gr = g + row * bpr;
+				for (int col = 0; col < fw; col++) {
+					if (!(gr[col >> 3] & (0x80 >> (col & 7))))
+						continue;
+					int xx = bx + col, yy = by + row;
+					if (pass == 0) {
+						for (int dy = -1; dy <= 1; dy++)
+							for (int dx = -1; dx <= 1; dx++) {
+								int ox = xx + dx, oy = yy + dy;
+								if (ox < 0 || ox >= _scaleBuf->w || oy < 0 || oy >= _scaleBuf->h)
+									continue;
+								hp[oy * hpitch + ox] = ol;
+							}
+					} else {
+						if (xx < 0 || xx >= _scaleBuf->w || yy < 0 || yy >= _scaleBuf->h)
+							continue;
+						hp[yy * hpitch + xx] = tc;
+					}
+				}
+			}
+		}
+		Common::Rect dirty(x, y, x + fw, y + fh);
+		updateBackendSurface(&dirty);
+		return;
+	}
+
+	// 非 hires fallback: 16px 字直繪 backend surface
+	Graphics::Surface *screen = getBackendSurface();
+	byte *sp = (byte *)screen->getPixels();
+	uint pitch = screen->pitch;
+	int oy = (int)y - (fh - 8);
+	if (oy < 0) oy = 0;
+	for (int row = 0; row < fh; row++) {
+		int yy = oy + row;
+		if (yy < 0 || yy >= screen->h) continue;
+		const byte *gr = g + row * bpr;
+		byte *d = sp + yy * pitch + x;
+		for (int col = 0; col < fw; col++) {
+			if ((int)x + col >= screen->w) break;
+			if (gr[col >> 3] & (0x80 >> (col & 7)))
+				d[col] = tc;
+		}
+	}
+	Common::Rect dirty(x, oy, x + fw, oy + fh);
+	updateBackendSurface(&dirty);
+}
+
+// ===== 非上游: 現代玩家友善化 — 動態自動地圖(WW) =====
+// 從當前房間 BFS 走 N/E/S/W 出口佈 2D 座標, 畫格+牆(roomExitStates)+當前位置+寶物標記,
+// 畫進 hi-res _scaleBuf 疊層。TAB 切換。怪物固定放置(見 docs/DYNAMIC_MAP_FEASIBILITY.md)。
+bool AGOSEngine::chtRoomHasTreasure(uint16 roomId) {
+	Item *room = derefItem(roomId);
+	if (!room)
+		return false;
+	uint16 cid = room->child;
+	int guard = 0;
+	while (cid && guard++ < 200) {
+		Item *c = derefItem(cid);
+		if (!c)
+			break;
+		SubObject *so = (SubObject *)findChildOfType(c, kObjectType);
+		if (so && (so->objectFlags & kOFIcon))
+			return true;
+		cid = c->next;
+	}
+	return false;
+}
+
+void AGOSEngine::chtDrawMapLabel(int x, int y, const char *big5) {
+	if (!_scaleBuf || !_cht.font16)
+		return;
+	const byte *s = (const byte *)big5;
+	int cx = x, fw = _cht.fontW16, fh = _cht.fontH16, bpr = _cht.fontBpr16;
+	byte tc = chtReadableColor(15);
+	byte *hp = (byte *)_scaleBuf->getPixels();
+	uint pitch = _scaleBuf->pitch;
+	while (*s) {
+		if (chtIsBig5Lead(*s) && s[1]) {
+			const byte *g = _cht.glyph16(s[0], s[1]);
+			s += 2;
+			if (g) {
+				for (int row = 0; row < fh; row++) {
+					int yy = y + row;
+					if (yy < 0 || yy >= _scaleBuf->h) continue;
+					const byte *gr = g + row * bpr;
+					byte *d = hp + yy * pitch + cx;
+					for (int col = 0; col < fw; col++) {
+						if (cx + col < 0 || cx + col >= _scaleBuf->w) break;
+						if (gr[col >> 3] & (0x80 >> (col & 7))) d[col] = tc;
+					}
+				}
+			}
+			cx += fw;
+		} else {
+			s++;
+		}
+	}
+}
+
+void AGOSEngine::chtDrawMap() {
+	if (!_chtHires || !_scaleBuf || getGameType() != GType_WW)
+		return;
+	const int MAXR = 300;
+	uint16 ids[MAXR]; int cxr[MAXR], cyr[MAXR];
+	int n = 0, head = 0;
+	ids[0] = _currentRoom; cxr[0] = 0; cyr[0] = 0; n = 1;
+	static const int ddx[4] = {0, 1, 0, -1}, ddy[4] = {-1, 0, 1, 0};   // 0北 1東 2南 3西
+	while (head < n) {
+		uint16 rid = ids[head]; int rx = cxr[head], ry = cyr[head]; head++;
+		Item *room = derefItem(rid);
+		if (!room) continue;
+		for (int d = 0; d < 4; d++) {
+			if (getDoorState(room, d) == 0) continue;   // 牆
+			uint16 ex = getExitOf(room, d);
+			if (ex == 0) continue;
+			bool have = false;
+			for (int k = 0; k < n; k++) if (ids[k] == ex) { have = true; break; }
+			if (have || n >= MAXR) continue;
+			ids[n] = ex; cxr[n] = rx + ddx[d]; cyr[n] = ry + ddy[d]; n++;
+		}
+	}
+	int minx = 0, maxx = 0, miny = 0, maxy = 0;
+	for (int k = 0; k < n; k++) {
+		if (cxr[k] < minx) minx = cxr[k]; if (cxr[k] > maxx) maxx = cxr[k];
+		if (cyr[k] < miny) miny = cyr[k]; if (cyr[k] > maxy) maxy = cyr[k];
+	}
+	int cols = maxx - minx + 1, rows = maxy - miny + 1;
+	int panelX = 40, panelY = 56, panelW = 560, panelH = 300;
+	int cell = panelW / (cols > 0 ? cols : 1);
+	int cellv = panelH / (rows > 0 ? rows : 1);
+	if (cellv < cell) cell = cellv;
+	if (cell > 26) cell = 26;
+	if (cell < 7) cell = 7;
+	int gridW = cols * cell, gridH = rows * cell;
+	int ox = panelX + (panelW - gridW) / 2, oy = panelY + (panelH - gridH) / 2;
+
+	byte *hp = (byte *)_scaleBuf->getPixels();
+	uint pitch = _scaleBuf->pitch;
+	byte dark = chtOutlineColor();
+	byte wallc = chtReadableColor(15);
+	// 找一個「暖色/金色」索引標寶物(高 R+G 低 B); 找不到就退回 wallc
+	byte gold = wallc; { int best = -1; const byte *p = _currentPalette;
+		for (int i = 1; i < 256; i++) { int r = p[i*3], g = p[i*3+1], b = p[i*3+2];
+			if (r > 150 && g > 110 && b < 100) { int sc = r + g - b; if (sc > best) { best = sc; gold = (byte)i; } } } }
+
+#define MP(X, Y, C) do { int _x=(X), _y=(Y); if (_x>=0 && _x<_scaleBuf->w && _y>=0 && _y<_scaleBuf->h) hp[_y*pitch+_x]=(C); } while(0)
+	// 背景板
+	for (int yy = panelY - 28; yy < panelY + panelH + 8; yy++) {
+		if (yy < 0 || yy >= _scaleBuf->h) continue;
+		for (int xx = panelX - 18; xx < panelX + panelW + 18; xx++) MP(xx, yy, dark);
+	}
+	chtDrawMapLabel(panelX - 10, panelY - 26, "\xa6\x61\xb9\xcf");   // 地圖
+
+	for (int k = 0; k < n; k++) {
+		int gx = ox + (cxr[k] - minx) * cell;
+		int gy = oy + (cyr[k] - miny) * cell;
+		Item *room = derefItem(ids[k]);
+		if (!room) continue;
+		bool cur = (ids[k] == _currentRoom);
+		if (cur) {   // 當前房間: 內部填亮色
+			for (int yy = gy + 2; yy < gy + cell - 2; yy++)
+				for (int xx = gx + 2; xx < gx + cell - 2; xx++) MP(xx, yy, wallc);
+		}
+		for (int d = 0; d < 4; d++) {   // 牆: door==0 畫線
+			bool wall = (getDoorState(room, d) == 0);
+			if (!wall) continue;
+			if (d == 0) for (int xx = gx; xx < gx + cell; xx++) MP(xx, gy, wallc);
+			if (d == 2) for (int xx = gx; xx < gx + cell; xx++) MP(xx, gy + cell - 1, wallc);
+			if (d == 3) for (int yy = gy; yy < gy + cell; yy++) MP(gx, yy, wallc);
+			if (d == 1) for (int yy = gy; yy < gy + cell; yy++) MP(gx + cell - 1, yy, wallc);
+		}
+		if (!cur && chtRoomHasTreasure(ids[k])) {   // 寶物: 中心金色方塊
+			int cxp = gx + cell / 2, cyp = gy + cell / 2;
+			for (int yy = cyp - 1; yy <= cyp + 1; yy++)
+				for (int xx = cxp - 1; xx <= cxp + 1; xx++) MP(xx, yy, gold);
+		}
+	}
+	// 圖例: 白格：你所在　黃點：寶物　　ＴＡＢ開關地圖
+	chtDrawMapLabel(panelX - 10, panelY + panelH - 6,
+		"\xa5\xd5\xae\xe6\xa1\x47\xa7\x41\xa9\xd2\xa6\x62\xa1\x40\xb6\xc0\xc2\x49\xa1\x47\xc4\x5f\xaa\xab\xa1\x40\xa1\x40\xa2\xe2\xa2\xcf\xa2\xd0\xb6\x7d\xc3\xf6\xa6\x61\xb9\xcf");
+#undef MP
+}
